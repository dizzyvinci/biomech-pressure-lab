# Python
__pycache__/
*.pyc
.venv/
venv/
.env

# Analysis outputs (regenerated) — anchored to root so the committed
# worked example under sample/results/ is NOT ignored.
/results/
/analysis/results/

# Raw captures (large / personal) — commit a small sample if you want
logs/
*.log

# Scans / meshes (large binaries)
scans/
*.stl
*.obj
*.ply
# ...but DO ship the small printable models (rendered from hardware/*.scad)
!hardware/*.stl

# Arduino / PlatformIO build
firmware/**/build/
.pio/

# OS
.DS_Store
Thumbs.db
